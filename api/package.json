{
  "name": "backend",
  "version": "0.1.8",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run clear && nest build",
    "clear": "rimraf dist *.tsbuildinfo",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "migration:run": "npm run build && typeorm migration:run -d dist/database/data-source.js",
    "migration:dev": "typeorm migration:run -d dist/database/data-source.js",
    "test:unit": "jest --passWithNoTests --testPathIgnorePatterns=\"\\\\.e2e\\\\.spec\\\\.ts$\"",
    "test:e2e": "npm run migration:run && jest --runInBand --testPathPatterns=\"\\\\.e2e\\\\.spec\\\\.ts$\"",
    "docker:prod": "docker compose --project-directory . -f ./docker-compose/docker-compose.prod.yml pull && docker compose --project-directory . -f ./docker-compose/docker-compose.prod.yml up -d",
    "docker:test": "docker compose -f ./docker-compose/docker-compose.test.yml up --build --abort-on-container-exit --exit-code-from backend",
    "db:up": "docker compose -f ./docker-compose/docker-compose.yml up -d",
    "db:down": "docker compose -f ./docker-compose/docker-compose.yml down",
    "seed": "ts-node src/scripts/seed.ts",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1077.0",
    "@aws-sdk/s3-request-presigner": "^3.1077.0",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "grammy": "^1.43.0",
    "handlebars": "^4.7.9",
    "nestjs-pino": "^4.5.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "rimraf": "^6.1.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.1",
    "@faker-js/faker": "^9.9.0",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.9",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/parser": "^8.48.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "prettier": "^3.7.4",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "/node_modules/(?!@cliplink/)"
    ]
  }
}
