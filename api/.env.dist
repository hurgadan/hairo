APP_NAME=hairo

PORT=3001
NODE_ENV=development
LOG_LEVEL=info

DB_HOST=localhost
DB_PORT=5432
DB_LOGIN=postgres
DB_PASSWORD=123123
DB_NAME=hairo
DB_ENABLE_LOGGING=false

RECIPIENT=
TELEGRAM_BOT_TOKEN=

JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# S3-совместимое хранилище (dev: MinIO из docker-compose)
# prod: Cloudflare R2 (endpoint https://<account>.eu.r2.cloudflarestorage.com,
#       region=auto, FORCE_PATH_STYLE=false, PUBLIC_URL=CDN-домен бакета)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=eu-central-1
STORAGE_ACCESS_KEY_ID=hairo
STORAGE_SECRET_ACCESS_KEY=hairo_dev_secret
STORAGE_BUCKET=hairo-photos
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_URL=

# Модель генерации изображений (Nano Banana / Gemini 2.5 Flash Image)
IMAGE_MODEL=gemini-2.5-flash-image
GOOGLE_AI_API_KEY=
